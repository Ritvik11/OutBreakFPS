# =============================================================================
# OutBreakFPS — .gitignore
# Merged from GitHub's UnrealEngine template + extras for portfolio hygiene.
# Pair with .gitattributes (Git LFS) — commit .gitattributes FIRST.
# =============================================================================

# -----------------------------------------------------------------------------
# IDE / editor user-specific
# -----------------------------------------------------------------------------
.vs/
.vsconfig
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Compiled artifacts
# -----------------------------------------------------------------------------
*.slo
*.lo
*.o
*.obj
*.gch
*.pch
*.so
*.dylib
*.dll
*.lai
*.la
*.a
*.lib
*.exe
*.out
*.app
*.ipa
*.mod

# -----------------------------------------------------------------------------
# UE-generated project files (regenerated from .uproject)
# -----------------------------------------------------------------------------
*.xcodeproj/
*.xcworkspace/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.opendb
*.pdb

# -----------------------------------------------------------------------------
# UE-generated folders
# -----------------------------------------------------------------------------
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

Plugins/**/Binaries/
Plugins/**/Build/
Plugins/**/Intermediate/
Plugins/**/Saved/

# Whitelist exceptions (keep certain Build/ items)
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# -----------------------------------------------------------------------------
# Source art (uncompressed working files — regeneratable into UE assets)
# -----------------------------------------------------------------------------
SourceArt/**/*.png
SourceArt/**/*.tga

# -----------------------------------------------------------------------------
# Built lighting data (regenerates from Build → Build Lighting Only)
# -----------------------------------------------------------------------------
*_BuiltData.uasset

# -----------------------------------------------------------------------------
# Packaged output — never commit; ship via GitHub Releases
# -----------------------------------------------------------------------------
Builds/
Packaged/

# -----------------------------------------------------------------------------
# Profiler / capture / crash dumps
# -----------------------------------------------------------------------------
*.dmp
crashdump_*/
*.utrace
*.uprof
*.rprof

# -----------------------------------------------------------------------------
# Secrets / local-only config
# -----------------------------------------------------------------------------
Config/LocalUser/
*.local.ini
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Auto-generated source (UHT output)
# -----------------------------------------------------------------------------
*.generated.h
*.generated.cpp
*.gen.cpp

# -----------------------------------------------------------------------------
# OS cruft
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/
